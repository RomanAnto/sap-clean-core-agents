# =============================================================================
# sap.env.example — SAP Connection Configuration Template
#
# Copy this file to mcp/sap.env and fill in your SAP system details:
#   cp mcp/sap.env.example mcp/sap.env
#
# Store the SAP password separately (NEVER in this file):
#   echo -n "your_password" > secrets/sap_password
#   chmod 600 secrets/sap_password          ← 600 = owner read/write only
#
# Both mcp/sap.env and secrets/sap_password are git-ignored.
# NEVER commit either file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Required — SAP System Connection
# ---------------------------------------------------------------------------

# Hostname or IP address of the SAP application server
SAP_HOST=your-sap-host.example.com

# SAP client number (three digits, e.g. 100, 200, 800)
SAP_CLIENT=100

# SAP ABAP username with ADT authorisations
# Required authorisation objects: S_ADT_RES, S_DEVELOP (display), S_CTS_ADMI
SAP_USERNAME=your_username

# SAP instance number (two digits, typically 00)
SAP_INSTANCE=00

# ---------------------------------------------------------------------------
# Optional — TLS / HTTPS
# ---------------------------------------------------------------------------

# Use HTTPS instead of HTTP (strongly recommended for production)
# true = connect via port 443/HTTPS | false = connect via port 8000/HTTP
SAP_SECURE=true

# Validate TLS certificates (strongly recommended for production)
# Set to false ONLY in isolated development environments with self-signed certs
# WARNING: false disables certificate verification entirely (MITM risk)
SSL_VERIFY=true

# ---------------------------------------------------------------------------
# Optional — MCP Server
# ---------------------------------------------------------------------------

# IP address the MCP server binds to (default: 127.0.0.1 loopback only)
# Change to 0.0.0.0 only if remote access is needed (and add firewall rules)
SERVER_HOST=127.0.0.1

# TCP port for the MCP server (default: 8001)
SERVER_PORT=8001

# Logging level: DEBUG | INFO | WARNING | ERROR
SERVER_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Optional — CORS
# Disabled by default. Enable only if a browser-based client needs access.
# ---------------------------------------------------------------------------

# Enable CORS support (default: false — keep disabled unless needed)
CORS_ENABLED=false

# Comma-separated list of allowed origins (required when CORS_ENABLED=true)
# Wildcard '*' is NOT accepted — specify exact origins only
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,https://myapp.example.com
# CORS_ALLOWED_ORIGINS=
