# =============================================================================
# portkey.env.example — Portkey AI Gateway Configuration Template
#
# Portkey acts as a model-agnostic LLM gateway that routes agent requests to
# any supported provider (Anthropic, OpenAI, Azure OpenAI, AWS Bedrock, etc.)
# without changing agent code.
#
# Setup:
#   cp mcp/portkey.env.example mcp/portkey.env
#   # Edit mcp/portkey.env with your actual keys
#
# mcp/portkey.env is git-ignored. NEVER commit it to version control.
# Store provider API keys as Portkey virtual keys (see dashboard setup below).
#
# Dashboard: https://app.portkey.ai
# Docs:      https://portkey.ai/docs
# =============================================================================

# ---------------------------------------------------------------------------
# Required — Portkey Gateway
# ---------------------------------------------------------------------------

# Your Portkey API key (from https://app.portkey.ai/api-keys)
PORTKEY_API_KEY=pk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Portkey gateway base URL (default is cloud; use self-hosted URL if applicable)
PORTKEY_BASE_URL=https://api.portkey.ai/v1

# ---------------------------------------------------------------------------
# Virtual Keys — Map provider API keys to Portkey aliases
#
# Create virtual keys at: https://app.portkey.ai/virtual-keys
# Each virtual key securely stores a provider API key (Anthropic, OpenAI, etc.)
# Reference them here by their Portkey slug.
#
# Example slugs: anthropic-key-abc123, openai-key-def456
# ---------------------------------------------------------------------------

# Virtual key for HIGH-capability agents (abap-accelerator, abap-fix-planner)
# Default model: claude-opus-4-5  |  Alternatives: gpt-4o, gemini-1.5-pro
PORTKEY_VIRTUAL_KEY_HIGH=anthropic-key-xxxxxxxx

# Virtual key for STANDARD agents (sap-atc-checker, documenter, biz-func-mapper)
# Default model: claude-sonnet-4-5  |  Alternatives: gpt-4o-mini, claude-3-5-sonnet
PORTKEY_VIRTUAL_KEY_STANDARD=anthropic-key-xxxxxxxx

# Virtual key for FAST/high-volume agents (sap-unused-code-discovery)
# Default model: claude-haiku-3-5  |  Alternatives: gpt-4o-mini, gemini-flash
PORTKEY_VIRTUAL_KEY_FAST=anthropic-key-xxxxxxxx

# ---------------------------------------------------------------------------
# Model Overrides — Override the default model per tier
#
# Leave blank to use the defaults coded in each agent JSON.
# Set to any model name supported by the virtual key's provider.
#
# Examples (Anthropic):  claude-opus-4-5 | claude-sonnet-4-5 | claude-haiku-3-5
# Examples (OpenAI):     gpt-4o          | gpt-4o-mini       | gpt-3.5-turbo
# Examples (Azure):      gpt-4           | gpt-35-turbo
# ---------------------------------------------------------------------------

# Model used by agents that require deep reasoning (complex analysis, fix planning)
# Kiro env var: AGENT_MODEL_HIGH
AGENT_MODEL_HIGH=claude-opus-4-5

# Model used by agents running standard analysis and documentation tasks
# Kiro env var: AGENT_MODEL_STANDARD
AGENT_MODEL_STANDARD=claude-sonnet-4-5

# Model used by agents performing high-volume, fast structural queries
# Kiro env var: AGENT_MODEL_FAST
AGENT_MODEL_FAST=claude-haiku-3-5

# ---------------------------------------------------------------------------
# Optional — Portkey Observability & Control
# ---------------------------------------------------------------------------

# Trace ID prefix added to all Portkey requests (useful for log correlation)
# PORTKEY_TRACE_ID_PREFIX=sap-clean-core

# Retry failed LLM requests automatically (Portkey feature)
# PORTKEY_RETRY_COUNT=3

# Cache identical LLM requests (reduces cost for repeated analysis)
# PORTKEY_CACHE_ENABLED=true
# PORTKEY_CACHE_TTL=3600

# ---------------------------------------------------------------------------
# Optional — Self-Hosted / Enterprise Portkey
# ---------------------------------------------------------------------------

# Override if running Portkey on-premises or in a private cloud
# PORTKEY_BASE_URL=https://portkey.your-domain.com/v1
